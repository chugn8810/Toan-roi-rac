#include <stdio.h>
#include <math.h>
#include <string.h>
long long euler[1000005];
void sangeuler()
{
   for (int i = 0; i < 100000; i++)
   {
      euler[i] = i;
   }
   for (int i = 2; i < 100000; i++)
   {
      if (euler[i] == i)
         for (int j = i; j < 100000; j += i)
         {
            euler[j] -= euler[j] / i;
         }
   }
}
int main()
{
   sangeuler();
   int m, tong = 1;
   scanf("%d", &m);
   for (int i = 1; i <=m; i++)
   {
      tong += euler[i];
   }
   printf("%d", tong);
}
